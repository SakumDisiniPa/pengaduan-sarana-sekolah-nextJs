            "length": 8,
            "emailTemplate": {
                "subject": "OTP for {APP_NAME}",
                "body": "<!DOCTYPE html>\n<html lang=\"id\">\n<body style=\"margin: 0; padding: 0; background-color: #f4f7fb; font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;\">\n  <table role=\"presentation\" width=\"100%\" cellspacing=\"0\" cellpadding=\"0\" border=\"0\">\n    <tr>\n      <td align=\"center\" style=\"padding: 40px 10px;\">\n        <table role=\"presentation\" width=\"100%\" style=\"max-width: 500px; background-color: #ffffff; border-radius: 24px; overflow: hidden; box-shadow: 0 10px 25px rgba(0,0,0,0.05);\" cellspacing=\"0\" cellpadding=\"0\" border=\"0\">\n          \n          <tr>\n            <td style=\"background: linear-gradient(135deg, #1e2b3c 0%, #0f212f 100%); padding: 35px 30px; text-align: center;\">\n              <h1 style=\"margin: 0; font-size: 24px; font-weight: 700; color: #ffffff; letter-spacing: -0.5px;\">{APP_NAME}</h1>\n              <p style=\"margin: 5px 0 0; font-size: 13px; color: #b3d0e6; font-weight: 400;\">Verifikasi Keamanan Akun</p>\n            </td>\n          </tr>\n\n          <tr>\n            <td style=\"padding: 40px 35px;\">\n              <h2 style=\"margin: 0 0 15px; font-size: 20px; font-weight: 600; color: #1e2b3c;\">Halo,</h2>\n              <p style=\"margin: 0 0 30px; font-size: 16px; color: #4a5568; line-height: 1.6;\">\n                Anda baru saja meminta kode akses untuk masuk ke akun Anda. Gunakan kode verifikasi di bawah ini untuk melanjutkan:\n              </p>\n\n              <table role=\"presentation\" width=\"100%\" cellspacing=\"0\" cellpadding=\"0\" border=\"0\">\n                <tr>\n                  <td align=\"center\" style=\"background-color: #f8fafc; border: 1px solid #e2e8f0; border-radius: 16px; padding: 30px 20px;\">\n                    <span style=\"display: block; font-size: 12px; font-weight: 700; color: #64748b; letter-spacing: 1.5px; margin-bottom: 15px; text-transform: uppercase;\">KODE OTP ANDA</span>\n                    <div style=\"display: inline-block; background-color: #ffffff; padding: 12px 25px; border-radius: 12px; border: 1px solid #cbd5e1; box-shadow: 0 4px 6px rgba(0,0,0,0.02);\">\n                      <span style=\"font-family: 'Courier New', Courier, monospace; font-size: 38px; font-weight: 800; color: #0f172a; letter-spacing: 8px;\">{OTP}</span>\n                    </div>\n                    <p style=\"margin: 15px 0 0; font-size: 12px; color: #94a3b8;\">Kode ini akan kedaluwarsa dalam 10 menit.</p>\n                  </td>\n                </tr>\n              </table>\n\n              <table role=\"presentation\" width=\"100%\" cellspacing=\"0\" cellpadding=\"0\" border=\"0\" style=\"margin-top: 30px;\">\n                <tr>\n                  <td style=\"background-color: #fffaf0; border-left: 4px solid #ed8936; padding: 15px; border-radius: 8px;\">\n                    <p style=\"margin: 0; font-size: 13px; color: #744210; line-height: 1.5;\">\n                      <strong>Peringatan Keamanan:</strong> Jangan berikan kode ini kepada siapapun. Tim {APP_NAME} tidak akan pernah meminta kode Anda melalui telepon atau chat.\n                    </p>\n                  </td>\n                </tr>\n              </table>\n            </td>\n          </tr>\n\n          <tr>\n            <td style=\"padding: 25px 35px; background-color: #fcfcfc; border-top: 1px solid #f1f5f9; text-align: center;\">\n              <p style=\"margin: 0; font-size: 14px; color: #4a5568;\">Terima kasih,<br><strong>Tim {APP_NAME}</strong></p>\n              <p style=\"margin: 20px 0 0; font-size: 11px; color: #94a3b8; line-height: 1.4;\">\n                Email ini dikirim secara otomatis ke domain terdaftar Anda di <strong>pengaduansaranasekolah.sakum.my.id</strong>. Jika Anda tidak merasa meminta kode ini, silakan abaikan.\n              </p>\n            </td>\n          </tr>\n        </table>\n      </td>\n    </tr>\n  </table>\n</body>\n</html>"
            }
