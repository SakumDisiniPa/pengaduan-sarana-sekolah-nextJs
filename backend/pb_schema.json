        "verificationTemplate": {
            "subject": "Verify your {APP_NAME} email",
            "body": "<!DOCTYPE html>\n<html lang=\"id\">\n<body style=\"margin: 0; padding: 0; background-color: #f4f7fb; font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;\">\n  <table role=\"presentation\" width=\"100%\" cellspacing=\"0\" cellpadding=\"0\" border=\"0\">\n    <tr>\n      <td align=\"center\" style=\"padding: 40px 10px;\">\n        <table role=\"presentation\" width=\"100%\" style=\"max-width: 500px; background-color: #ffffff; border-radius: 28px; overflow: hidden; box-shadow: 0 15px 35px rgba(0,0,0,0.07);\" cellspacing=\"0\" cellpadding=\"0\" border=\"0\">\n          \n          <tr>\n            <td style=\"background: linear-gradient(135deg, #1e2b3c 0%, #0f212f 100%); padding: 45px 30px; text-align: center;\">\n              <div style=\"font-size: 13px; color: #b3d0e6; text-transform: uppercase; letter-spacing: 2px; margin-bottom: 10px; font-weight: 600;\">Selamat Datang</div>\n              <h1 style=\"margin: 0; font-size: 28px; font-weight: 700; color: #ffffff; letter-spacing: -0.5px;\">{APP_NAME}</h1>\n            </td>\n          </tr>\n\n          <tr>\n            <td style=\"padding: 45px 35px;\">\n              <h2 style=\"margin: 0 0 15px; font-size: 22px; font-weight: 600; color: #1e2b3c;\">Halo! 👋</h2>\n              <p style=\"margin: 0 0 25px; font-size: 16px; color: #4a5568; line-height: 1.6;\">\n                Terima kasih telah bergabung dengan <strong>{APP_NAME}</strong>. Satu langkah terakhir sebelum Anda mulai, silakan konfirmasi alamat email Anda dengan menekan tombol di bawah ini:\n              </p>\n\n              <table role=\"presentation\" width=\"100%\" cellspacing=\"0\" cellpadding=\"0\" border=\"0\">\n                <tr>\n                  <td align=\"center\" style=\"padding: 10px 0 35px;\">\n                    <a href=\"{APP_URL}/_/#/auth/confirm-verification/{TOKEN}\" target=\"_blank\" style=\"display: inline-block; background-color: #28a745; color: #ffffff; font-size: 16px; font-weight: 600; text-decoration: none; padding: 16px 45px; border-radius: 14px; box-shadow: 0 6px 18px rgba(40, 167, 69, 0.3);\">\n                      Verifikasi Akun Saya\n                    </a>\n                  </td>\n                </tr>\n              </table>\n\n              <p style=\"margin: 0 0 10px; font-size: 12px; color: #94a3b8; text-align: center;\">Jika tombol tidak berfungsi, salin link ini:</p>\n              <div style=\"background-color: #f8fafc; border: 1px dashed #cbd5e1; padding: 10px; border-radius: 8px; word-break: break-all; font-size: 11px; color: #64748b; text-align: center; font-family: monospace;\">\n                {APP_URL}/_/#/auth/confirm-verification/{TOKEN}\n              </div>\n            </td>\n          </tr>\n\n          <tr>\n            <td style=\"padding: 30px 35px; background-color: #fafcff; border-top: 1px solid #f1f5f9; text-align: center;\">\n              <p style=\"margin: 0; font-size: 14px; color: #4a5568;\">Sampai jumpa di aplikasi,<br><strong>Tim {APP_NAME}</strong></p>\n              <div style=\"margin: 25px 0 0; font-size: 11px; color: #94a3b8; line-height: 1.4;\">\n                Email ini dikirimkan untuk mengonfirmasi pendaftaran akun Anda di <strong>{APP_NAME}</strong> melalui domain <strong>pengaduansaranasekolah.sakum.my.id</strong>.\n              </div>\n            </td>\n          </tr>\n        </table>\n      </td>\n    </tr>\n  </table>\n</body>\n</html>"
        },
        "resetPasswordTemplate": {
            "subject": "Reset your {APP_NAME} password",
            "body": "<!DOCTYPE html>\n<html lang=\"id\">\n<body style=\"margin: 0; padding: 0; background-color: #f4f7fb; font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;\">\n  <table role=\"presentation\" width=\"100%\" cellspacing=\"0\" cellpadding=\"0\" border=\"0\">\n    <tr>\n      <td align=\"center\" style=\"padding: 40px 10px;\">\n        <table role=\"presentation\" width=\"100%\" style=\"max-width: 500px; background-color: #ffffff; border-radius: 24px; overflow: hidden; box-shadow: 0 10px 25px rgba(0,0,0,0.05);\" cellspacing=\"0\" cellpadding=\"0\" border=\"0\">\n          \n          <tr>\n            <td style=\"background: linear-gradient(135deg, #1e2b3c 0%, #0f212f 100%); padding: 35px 30px; text-align: center;\">\n              <h1 style=\"margin: 0; font-size: 24px; font-weight: 700; color: #ffffff; letter-spacing: -0.5px;\">{APP_NAME}</h1>\n              <p style=\"margin: 5px 0 0; font-size: 13px; color: #b3d0e6; font-weight: 400;\">Atur Ulang Kata Sandi</p>\n            </td>\n          </tr>\n\n          <tr>\n            <td style=\"padding: 40px 35px;\">\n              <h2 style=\"margin: 0 0 15px; font-size: 20px; font-weight: 600; color: #1e2b3c;\">Halo,</h2>\n              <p style=\"margin: 0 0 25px; font-size: 16px; color: #4a5568; line-height: 1.6;\">\n                Kami menerima permintaan untuk mengatur ulang kata sandi akun <strong>{APP_NAME}</strong> Anda. Silakan klik tombol di bawah ini untuk membuat kata sandi baru:\n              </p>\n\n              <table role=\"presentation\" width=\"100%\" cellspacing=\"0\" cellpadding=\"0\" border=\"0\">\n                <tr>\n                  <td align=\"center\" style=\"padding: 10px 0 30px;\">\n                    <a href=\"{APP_URL}/_/#/auth/confirm-password-reset/{TOKEN}\" target=\"_blank\" style=\"display: inline-block; background-color: #dc3545; color: #ffffff; font-size: 16px; font-weight: 600; text-decoration: none; padding: 15px 35px; border-radius: 12px; box-shadow: 0 4px 12px rgba(220, 53, 69, 0.3);\">\n                      Reset Kata Sandi\n                    </a>\n                  </td>\n                </tr>\n              </table>\n\n              <table role=\"presentation\" width=\"100%\" cellspacing=\"0\" cellpadding=\"0\" border=\"0\">\n                <tr>\n                  <td style=\"background-color: #fff8e7; border-left: 4px solid #f5b042; padding: 15px; border-radius: 8px;\">\n                    <p style=\"margin: 0; font-size: 13px; color: #7a6300; line-height: 1.5;\">\n                      <strong>Penting:</strong> Jika Anda tidak meminta pengaturan ulang kata sandi, abaikan email ini. Kata sandi Anda tidak akan berubah tanpa tindakan lebih lanjut.\n                    </p>\n                  </td>\n                </tr>\n              </table>\n            </td>\n          </tr>\n\n          <tr>\n            <td style=\"padding: 25px 35px; background-color: #fcfcfc; border-top: 1px solid #f1f5f9; text-align: center;\">\n              <p style=\"margin: 0; font-size: 14px; color: #4a5568;\">Terima kasih,<br><strong>Tim {APP_NAME}</strong></p>\n              <div style=\"margin: 20px 0 0; font-size: 11px; color: #94a3b8; line-height: 1.4;\">\n                &copy; 2026 {APP_NAME}. Keamanan Anda adalah tanggung jawab kami.\n              </div>\n            </td>\n          </tr>\n        </table>\n      </td>\n    </tr>\n  </table>\n</body>\n</html>"
        },
        "confirmEmailChangeTemplate": {
            "subject": "Confirm your {APP_NAME} new email address",
            "body": "<!DOCTYPE html>\n<html lang=\"id\">\n<body style=\"margin: 0; padding: 0; background-color: #f4f7fb; font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;\">\n  <table role=\"presentation\" width=\"100%\" cellspacing=\"0\" cellpadding=\"0\" border=\"0\">\n    <tr>\n      <td align=\"center\" style=\"padding: 40px 10px;\">\n        <table role=\"presentation\" width=\"100%\" style=\"max-width: 500px; background-color: #ffffff; border-radius: 24px; overflow: hidden; box-shadow: 0 10px 25px rgba(0,0,0,0.05);\" cellspacing=\"0\" cellpadding=\"0\" border=\"0\">\n          \n          <tr>\n            <td style=\"background: linear-gradient(135deg, #1e2b3c 0%, #0f212f 100%); padding: 35px 30px; text-align: center;\">\n              <h1 style=\"margin: 0; font-size: 24px; font-weight: 700; color: #ffffff; letter-spacing: -0.5px;\">{APP_NAME}</h1>\n              <p style=\"margin: 5px 0 0; font-size: 13px; color: #b3d0e6; font-weight: 400;\">Pembaruan Keamanan Akun</p>\n            </td>\n          </tr>\n\n          <tr>\n            <td style=\"padding: 40px 35px;\">\n              <h2 style=\"margin: 0 0 15px; font-size: 20px; font-weight: 600; color: #1e2b3c;\">Halo,</h2>\n              <p style=\"margin: 0 0 25px; font-size: 16px; color: #4a5568; line-height: 1.6;\">\n                Kami menerima permintaan untuk mengubah alamat email akun <strong>{APP_NAME}</strong> Anda. Silakan konfirmasi alamat email baru Anda dengan menekan tombol di bawah ini:\n              </p>\n\n              <table role=\"presentation\" width=\"100%\" cellspacing=\"0\" cellpadding=\"0\" border=\"0\">\n                <tr>\n                  <td align=\"center\" style=\"padding: 10px 0 30px;\">\n                    <a href=\"{APP_URL}/_/#/auth/confirm-email-change/{TOKEN}\" target=\"_blank\" style=\"display: inline-block; background-color: #007bff; color: #ffffff; font-size: 16px; font-weight: 600; text-decoration: none; padding: 15px 35px; border-radius: 12px; box-shadow: 0 4px 12px rgba(0, 123, 255, 0.3);\">\n                      Konfirmasi Email Baru\n                    </a>\n                  </td>\n                </tr>\n              </table>\n\n              <p style=\"margin: 0; font-size: 13px; color: #94a3b8; font-style: italic; line-height: 1.5; text-align: center;\">\n                Jika Anda tidak merasa meminta perubahan ini, Anda dapat mengabaikan email ini dengan aman. Alamat email Anda tidak akan berubah tanpa konfirmasi ini.\n              </p>\n            </td>\n          </tr>\n\n          <tr>\n            <td style=\"padding: 25px 35px; background-color: #fcfcfc; border-top: 1px solid #f1f5f9; text-align: center;\">\n              <p style=\"margin: 0; font-size: 14px; color: #4a5568;\">Terima kasih,<br><strong>Tim {APP_NAME}</strong></p>\n              <div style=\"margin: 20px 0 0; font-size: 11px; color: #94a3b8; line-height: 1.4;\">\n                &copy; 2026 {APP_NAME}. Dikirim melalui <strong>pengaduansaranasekolah.sakum.my.id</strong>\n              </div>\n            </td>\n          </tr>\n        </table>\n      </td>\n    </tr>\n  </table>\n</body>\n</html>"
        }
    },
