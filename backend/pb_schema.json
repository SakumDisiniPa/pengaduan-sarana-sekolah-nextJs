        "authAlert": {
            "enabled": true,
            "emailTemplate": {
                "subject": "Login from a new location",
                "body": "<!DOCTYPE html>\n<html>\n<body style=\"font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif; background-color: #f9f9f9; padding: 20px;\">\n    <div style=\"max-width: 600px; margin: 0 auto; background-color: #ffffff; border: 1px solid #eeeeee; border-radius: 8px; overflow: hidden;\">\n        <div style=\"background-color: #007bff; padding: 20px; text-align: center;\">\n            <h1 style=\"color: #ffffff; margin: 0; font-size: 24px;\">{APP_NAME} Security</h1>\n        </div>\n        \n        <div style=\"padding: 30px; color: #333333; line-height: 1.6;\">\n            <p style=\"font-size: 16px;\">Halo,</p>\n            <p>Kami mendeteksi adanya login baru ke akun <strong>{APP_NAME}</strong> kamu dari lokasi berikut:</p>\n            \n            <div style=\"background-color: #f1f1f1; padding: 15px; border-radius: 5px; margin: 20px 0; font-style: italic; font-family: monospace;\">\n                {ALERT_INFO}\n            </div>\n\n            <p style=\"color: #d9534f; font-weight: bold;\">Jika ini bukan kamu, segera amankan akun kamu dengan mengganti password sekarang juga!</p>\n            \n            <p>Jika ini memang kamu, silakan abaikan email ini.</p>\n        </div>\n\n        <div style=\"padding: 20px; text-align: center; font-size: 12px; color: #999999; border-top: 1px solid #eeeeee;\">\n            &copy; 2026 {APP_NAME}. Sakum Studios Security.\n        </div>\n    </div>\n</body>\n</html>"
            }
